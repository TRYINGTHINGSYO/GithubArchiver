# Required for GPT planning turns
OPENAI_API_KEY=sk-...

# Optional model override (default: gpt-4.1)
OPENAI_MODEL=gpt-4.1

# Optional: Cursor Agent CLI binary (default: agent)
# CURSOR_AGENT_BIN=agent

# Optional: Cursor API key for headless agent auth
# CURSOR_API_KEY=

# Local UI / API port (default: 8787)
PORT=8787

# Default max relay rounds (UI can override)
MAX_ROUNDS=8
