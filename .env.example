# Optional — strongly recommended for enrichment (5000 req/hr vs 60)
GITHUB_TOKEN=

# SQLite database path (default: ./data/githubarchive.db)
DATABASE_PATH=./data/githubarchive.db

# Local archive storage (default: ./data/archives)
ARCHIVE_DIR=./data/archives

# Archive worker limits
ARCHIVE_MAX_REPOS=10
ARCHIVE_MAX_BYTES=52428800
ARCHIVE_TIMEOUT_MS=120000
ARCHIVE_DELAY_MS=1000

# Enrichment worker limits
ENRICH_BATCH_SIZE=50
ENRICH_DELAY_MS=800

# Refresh worker (re-enrichment for repos enriched >24h ago)
REFRESH_BATCH_SIZE=50
REFRESH_DELAY_MS=800
REFRESH_INTERVAL_HOURS=24

# Override hour file for ingest:hour (default: previous UTC hour)
# GH_ARCHIVE_HOUR=2026-07-05-17

# Daemon loop (npm run daemon)
DAEMON_SLEEP_MIN_MS=300000
DAEMON_SLEEP_MAX_MS=900000
DAEMON_BACKOFF_BASE_MS=60000
DAEMON_BACKOFF_MAX_MS=900000
DAEMON_INGEST_MAX_HOURS=6
# DAEMON_INGEST_FROM=2026-07-05-00

# Local backup (npm run backup)
BACKUPS_DIR=./data/backups
# BACKUP_INCLUDE_ARCHIVES=1
# BACKUP_COMPRESS=1

# Restore (npm run restore) — stop daemon/dev server first
# RESTORE_BACKUP_PATH=./data/backups/YYYY-MM-DD_HH-mm-ss
# RESTORE_CONFIRM=1

# GH Archive ingest retries (recent hours only)
INGEST_RETRY_MAX=3
INGEST_RETRY_BASE_MS=5000
INGEST_RECENT_HOUR_WINDOW=3

# GitHub Search fallback (when GH Archive has events but 0 repo CreateEvents)
SEARCH_FALLBACK_MIN_EVENTS=1000
SEARCH_MAX_PAGES=10
SEARCH_PAGE_DELAY_MS=2000

# All-years backfill (npm run backfill:day | backfill:range | backfill:resume)
# BACKFILL_DAY=2024-06-15
# BACKFILL_START=2024-01-01
# BACKFILL_END=2024-12-31
# BACKFILL_SOURCE=auto
# BACKFILL_MAX_HOURS=6
# BACKFILL_JOB_ID=1
