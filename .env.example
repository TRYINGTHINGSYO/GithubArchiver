# Optional — strongly recommended for enrichment (5000 req/hr vs 60).
# Never commit a real token. For production, set GITHUB_TOKEN as a Railway
# environment variable instead of shipping a .env file.
GITHUB_TOKEN=

# SQLite database path (default: ./data/githubarchive.db)
DATABASE_PATH=./data/githubarchive.db

# Optional local artifact archive storage (default: ./data/archives)
ARCHIVE_DIR=./data/archives

# Metadata-only mode is the default for small disks/Railway volumes.
# Keeps discovery, enrichment, metrics, events, summaries, and intelligence running
# while disabling README/source/ZIP artifact downloads.
# Set ENABLE_ARTIFACT_ARCHIVE=1 to opt into heavy README/source/ZIP storage.
# METADATA_ONLY=1
# ENABLE_ARTIFACT_ARCHIVE=1

# Shared admin login. Change this in production; default is GitHub.
# ADMIN_PASSWORD=GitHub
# ADMIN_SESSION_SECRET=

# Storage pressure guard. When artifact archive storage is enabled, archive cycles
# clean non-favorite artifacts before free space drops below this threshold.
# STORAGE_MIN_FREE_BYTES=1073741824

# Artifact archive worker limits (used only with ENABLE_ARTIFACT_ARCHIVE=1)
ARCHIVE_MAX_REPOS=25
ARCHIVE_CONCURRENCY=3
ARCHIVE_BURST_CYCLES=3
ARCHIVE_BURST_BACKLOG_MIN=100
ARCHIVE_BACKLOG_SLEEP_MS=60000
ARCHIVE_BACKLOG_SLEEP_THRESHOLD=1000
ARCHIVE_MAX_BYTES=52428800
ARCHIVE_TIMEOUT_MS=120000
ARCHIVE_DELAY_MS=300

# Enrichment worker limits
# Level 1 = metadata only (~1 request/repo). Set ENRICH_SYNC_RELEASES=1 to also
# fetch releases/tags (+2 requests). Levels 2–3 stay in the archive worker.
ENRICH_BATCH_SIZE=50
ENRICH_DELAY_MS=800
ENRICH_LEVEL=1
# ENRICH_MAX_BATCHES=2
# ENRICH_SYNC_RELEASES=0
# Target a specific creation window instead of recent-first backlog:
# ENRICH_CREATED_FROM=2026-06-22T00:00:00Z
# ENRICH_CREATED_TO=2026-06-29T00:00:00Z
# Enrich only immutable members of a controlled dataset run (sample_rank order):
# ENRICH_DATASET_ID=3

# Refresh worker (re-enrichment for repos enriched >24h ago)
REFRESH_BATCH_SIZE=50
REFRESH_DELAY_MS=800
REFRESH_INTERVAL_HOURS=24

# Override hour file for ingest:hour (default: previous UTC hour)
# GH_ARCHIVE_HOUR=2026-07-05-17

# Daemon loop (npm run daemon)
DAEMON_SLEEP_MIN_MS=300000
DAEMON_SLEEP_MAX_MS=900000
DAEMON_BACKOFF_BASE_MS=60000
DAEMON_BACKOFF_MAX_MS=900000
DAEMON_INGEST_MAX_HOURS=6
# DAEMON_INGEST_FROM=2026-07-05-00

# Local backup (npm run backup)
BACKUPS_DIR=./data/backups
# BACKUP_INCLUDE_ARCHIVES=1
# BACKUP_COMPRESS=1

# Restore (npm run restore) — stop daemon/dev server first
# RESTORE_BACKUP_PATH=./data/backups/YYYY-MM-DD_HH-mm-ss
# RESTORE_CONFIRM=1

# GH Archive ingest retries (recent hours only)
INGEST_RETRY_MAX=3
INGEST_RETRY_BASE_MS=5000
INGEST_RECENT_HOUR_WINDOW=3

# GitHub Search fallback (when GH Archive has events but 0 repo CreateEvents)
SEARCH_FALLBACK_MIN_EVENTS=1000
SEARCH_MAX_PAGES=10
SEARCH_PAGE_DELAY_MS=2000
# Shard depth: 1=15min, 2=5min, 3=1min windows when total_count > 1000
SEARCH_SHARD_MAX_DEPTH=3

# Emerging discovery — under-the-radar band (~100–1000), not mega-star repos
TRENDING_MIN_STARS=100
TRENDING_MAX_STARS=1000
TRENDING_MAX_PAGES=3
TRENDING_PER_PAGE=50
TRENDING_PUSHED_DAYS=14
TRENDING_PAGE_DELAY_MS=1500
TRENDING_IDLE_INTERVAL_MS=1800000

# All-years backfill (npm run backfill:day | backfill:range | backfill:resume)
# BACKFILL_DAY=2024-06-15
# BACKFILL_START=2024-01-01
# BACKFILL_END=2024-12-31
# BACKFILL_SOURCE=auto
# BACKFILL_MAX_HOURS=6
# BACKFILL_JOB_ID=1

# Controlled comparable dataset runs (npm run dataset:create-pair | dataset:sample)
# DATASET_PREVIOUS_START=2026-06-22T00:00:00.000Z
# DATASET_PREVIOUS_END=2026-06-29T00:00:00.000Z
# DATASET_CURRENT_START=2026-06-29T00:00:00.000Z
# DATASET_CURRENT_END=2026-07-06T00:00:00.000Z
# DATASET_MAX_PER_HOUR=9
# DATASET_TARGET_SAMPLE_SIZE=1500
# DATASET_RUN_ID=1
# Strict matched-hour pair (npm run dataset:create-matched-pair):
# DATASET_COMPARISON_MODE=matched-hours
# DATASET_MATCHED_HOURS_PER_DAY=0,6,12,18
# DATASET_SAMPLE_PER_HOUR=25
# DATASET_CANDIDATE_POOL_SIZE=100
# DATASET_MATCHED_CONCURRENCY=2
# Bind detection to immutable dataset membership:
# EMERGING_CURRENT_DATASET_ID=2
# EMERGING_PREVIOUS_DATASET_ID=1
