# Required for GPT planning turns (or store via: foundry setup)
OPENAI_API_KEY=sk-...

# Optional model override (default: gpt-4.1)
OPENAI_MODEL=gpt-4.1

# Optional: Cursor Agent CLI binary (default: agent)
# CURSOR_AGENT_BIN=agent

# Optional: Cursor API key for headless agent auth
# CURSOR_API_KEY=

# Local UI / API port (default: 8787)
PORT=8787

# Default max orchestrator rounds (UI can override)
MAX_ROUNDS=12

# Optional: JSON map of project name → absolute path for auto-detect
# FOUNDRY_KNOWN_PROJECTS={"MyApp":"/path/to/MyApp"}

# Optional: extra roots to scan for project folders (path.delimiter-separated)
# FOUNDRY_PROJECT_ROOTS=/Users/you/Projects:/Users/you/code

# Optional: Foundry home (vault, memory, sessions, metrics). Default: ~/.foundry
# FOUNDRY_HOME=/home/you/.foundry

# Optional: extra entropy for the machine-local secret vault
# FOUNDRY_SECRET_KEY=

# Legacy aliases (still accepted):
# RELAY_KNOWN_PROJECTS=...
# RELAY_PROJECT_ROOTS=...
# RELAY_MEMORY_DIR=...
