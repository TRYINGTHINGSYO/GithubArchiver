{
  "name": "foundry",
  "version": "1.0.0-beta.1",
  "private": true,
  "type": "module",
  "description": "Foundry — local AI software engineering orchestrator (multi-agent, task graphs, plugins)",
  "bin": {
    "foundry": "./bin/foundry.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "setup": "tsx src/cli/setup.ts",
    "doctor": "tsx src/cli/doctor.ts",
    "diagnostics": "tsx src/cli/diagnostics.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
