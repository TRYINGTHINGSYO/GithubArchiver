{
  "name": "foundry",
  "version": "0.5.0-beta.1",
  "private": true,
  "type": "module",
  "description": "Foundry — local AI software engineering orchestrator",
  "bin": {
    "foundry": "./bin/foundry.js"
  },
  "files": [
    "bin",
    "dist",
    "public",
    "plugins",
    "adapters",
    "templates",
    "foundry.config.example.yaml",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "setup": "node dist/cli/setup.js",
    "doctor": "node dist/cli/doctor.js",
    "diagnostics": "node dist/cli/diagnostics.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.json --noEmit",
    "acceptance": "npm run build && node scripts/acceptance-project-birth.mjs",
    "acceptance:github": "npm run build && FOUNDRY_ACCEPTANCE_GITHUB=1 node scripts/acceptance-project-birth.mjs",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
